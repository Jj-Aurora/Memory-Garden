<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.memorygarden.mapper.BadgeMapper">

    <resultMap id="BaseResultMap" type="com.memorygarden.model.entity.Badge">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="icon" property="icon"/>
        <result column="rarity" property="rarity"/>
        <result column="condition_type" property="conditionType"/>
        <result column="condition_value" property="conditionValue"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, icon, rarity, condition_type, condition_value, is_deleted, create_time
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_badge
        WHERE is_deleted = 0
        ORDER BY rarity ASC, id ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_badge
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByConditionType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_badge
        WHERE condition_type = #{conditionType} AND is_deleted = 0
    </select>

</mapper>
