<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.memorygarden.mapper.UserBadgeMapper">

    <resultMap id="BaseResultMap" type="com.memorygarden.model.entity.UserBadge">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="badge_id" property="badgeId"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, badge_id, is_deleted, create_time
    </sql>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_user_badge
        WHERE user_id = #{userId} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <select id="existsByUserIdAndBadgeId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM t_user_badge
        WHERE user_id = #{userId} AND badge_id = #{badgeId} AND is_deleted = 0
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_user_badge (user_id, badge_id, is_deleted)
        VALUES (#{userId}, #{badgeId}, #{isDeleted})
    </insert>

</mapper>
